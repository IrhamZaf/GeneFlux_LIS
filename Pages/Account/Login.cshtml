@page
@model LIS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}

<div class="card lis-login-card">
    <div class="card-body p-5">
        <div class="text-center mb-4">
            <div class="mb-3">
                <img src="~/img/Geneflux_logo3.png" alt="Geneflux Logo" class="img-fluid" style="max-height: 60px;" />
            </div>
            <h4 class="mb-1">Welcome Back</h4>
            <p class="text-muted mb-0">Sign in to continue to Geneflux LIS.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-4" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" class="form-control form-control-lg" id="email" name="Email" value="@Model.Email" placeholder="Enter email" required>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label class="form-label" for="password-input">Password</label>
                    <a href="#" class="text-muted small">Forgot password?</a>
                </div>
                <div class="position-relative auth-pass-inputgroup">
                    <input type="password" class="form-control form-control-lg pe-5 password-input" placeholder="Enter password" id="password-input" name="Password" required>
                    <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-decoration-none text-muted password-addon" type="button" id="password-addon">
                        <i class="icon-base ti tabler-eye align-middle"></i>
                    </button>
                </div>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" name="RememberMe" value="true" id="auth-remember-check">
                <label class="form-check-label" for="auth-remember-check">Remember me</label>
            </div>

            <button class="btn btn-primary btn-lg w-100" type="submit">Sign In</button>

            <p class="text-center text-muted mt-4 mb-0">
                Hospital staff without an account? <a href="/account/register">Request access</a>
            </p>

            <div class="lis-demo-accounts mt-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar avatar-sm me-2">
                        <span class="avatar-initial rounded bg-label-info">
                            <i class="icon-base ti tabler-key"></i>
                        </span>
                    </div>
                    <h6 class="mb-0">Demo Accounts</h6>
                </div>
                <div class="vstack gap-2">
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-muted">Super Admin</span>
                        <code>superadmin@geneflux.com</code>
                    </div>
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-muted">Doctor (seed)</span>
                        <code class="text-break">tuang.wei.xuan@geneflux.com</code>
                    </div>
                    <div class="border-top pt-2 text-muted small">
                        Password format: <code>[Role]@("@123")</code>, for example <code>SuperAdmin@123</code>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
