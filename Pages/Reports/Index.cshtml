@page
@model LIS.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports";
}

<div class="card">
    <div class="card-header border-0">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h4 class="card-title mb-1">Recent Reports</h4>
                <p class="text-muted mb-0">Legacy Razor view for the unified report workspace.</p>
            </div>
            <button type="button" class="btn btn-primary btn-sm">
                <i class="icon-base ti tabler-plus me-1"></i>Add Report
            </button>
        </div>
    </div>

    <div class="card-body pt-0">
        <div class="card-datatable table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ref No</th>
                        <th>Patient</th>
                        <th>Hospital</th>
                        <th>Doctor</th>
                        <th>Test</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Reports)
                    {
                        <tr>
                            <td><a href="#" class="fw-medium">@item.ReferenceNumber</a></td>
                            <td>@item.Patient.Name</td>
                            <td>@item.Hospital.Name</td>
                            <td>@item.Doctor.Name</td>
                            <td>@item.Test.Name</td>
                            <td>
                                @if (item.Status == LIS.Models.ReportStatus.Approved)
                                {
                                    <span class="badge bg-label-success">Approved</span>
                                }
                                else if (item.Status == LIS.Models.ReportStatus.PendingReview)
                                {
                                    <span class="badge bg-label-info">Pending Review</span>
                                }
                                else if (item.Status == LIS.Models.ReportStatus.Draft)
                                {
                                    <span class="badge bg-label-warning">Draft</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-info">@item.Status</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd MMM, yyyy")</td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-icon btn-text-secondary rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="icon-base ti tabler-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="#"><i class="icon-base ti tabler-eye me-2"></i>View</a></li>
                                        <li><a class="dropdown-item" href="#"><i class="icon-base ti tabler-edit me-2"></i>Edit</a></li>
                                        <li><a class="dropdown-item" asp-page-handler="Download" asp-route-id="@item.Id"><i class="icon-base ti tabler-file-type-pdf me-2"></i>Download PDF</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
