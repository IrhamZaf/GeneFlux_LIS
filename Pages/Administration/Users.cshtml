@page
@model LIS.Pages.Administration.UsersModel
@{
    ViewData["Title"] = "User Management";
}

<div class="card">
    <div class="card-header border-0">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h4 class="card-title mb-1">Users List</h4>
                <p class="text-muted mb-0">Manage LIS accounts, roles, and access controls.</p>
            </div>
            <button type="button" class="btn btn-primary btn-sm">
                <i class="icon-base ti tabler-user-plus me-1"></i>Add User
            </button>
        </div>
    </div>

    <div class="card-body pt-0">
        <div class="card-datatable table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Roles</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-3">
                                        <span class="avatar-initial rounded-circle bg-label-info">
                                            @(item.FullName?.Substring(0, 1) ?? "U")
                                        </span>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">@item.FullName</h6>
                                        <small class="text-muted">@item.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var roles = item.Roles.Split(", ");
                                    foreach (var role in roles)
                                    {
                                        var badgeClass = role == "SuperAdmin" ? "bg-label-danger" : (role == "Admin" ? "bg-label-warning" : "bg-label-info");
                                        <span class="badge @badgeClass me-1">@role</span>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-icon btn-text-secondary rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="icon-base ti tabler-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="#"><i class="icon-base ti tabler-shield me-2"></i>Edit Roles</a></li>
                                        <li><a class="dropdown-item" href="#"><i class="icon-base ti tabler-key me-2"></i>Reset Password</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="#"><i class="icon-base ti tabler-trash me-2"></i>Delete</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
