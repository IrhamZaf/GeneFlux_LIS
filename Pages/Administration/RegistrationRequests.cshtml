@page "/administration/registration-requests"
@model LIS.Pages.Administration.RegistrationRequestsModel
@{
    ViewData["Title"] = "Staff registrations";
}

<div class="card">
    <div class="card-header border-0">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h4 class="card-title mb-1">Pending staff registrations</h4>
                <p class="text-muted mb-0">Approve to create the login account and hospital access. Reject to dismiss the request.</p>
            </div>
            <a href="/administration/users" class="btn btn-label-secondary btn-sm">Users</a>
        </div>
    </div>

    <div class="card-body pt-0">
        @if (!string.IsNullOrEmpty(Model.FlashMessage))
        {
            <div class="alert alert-info mb-4" role="alert">@Model.FlashMessage</div>
        }

        @if (Model.Pending.Count == 0)
        {
            <p class="text-muted mb-0">No pending registration requests.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Requested</th>
                            <th>Name / Email</th>
                            <th>NRIC</th>
                            <th>Phone</th>
                            <th>Hospital</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Pending)
                        {
                            <tr>
                                <td class="text-muted small">@r.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <div class="fw-semibold">@r.FullName</div>
                                    <div class="small text-muted">@r.Email</div>
                                </td>
                                <td class="small">@r.Nric</td>
                                <td class="small">
                                    @r.PhoneNumber
                                    @if (!string.IsNullOrEmpty(r.MmcNumber))
                                    {
                                        <div class="text-muted">MMC: @r.MmcNumber</div>
                                    }
                                </td>
                                <td>@r.Hospital.Name</td>
                                <td><span class="badge bg-label-primary">@r.RequestedRole</span></td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Approve" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-sm btn-success me-1">Approve</button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-label-danger" data-bs-toggle="modal" data-bs-target="#rejectModal@(r.Id)">Reject</button>

                                    <div class="modal fade" id="rejectModal@(r.Id)" tabindex="-1">
                                        <div class="modal-dialog">
                                            <form method="post" asp-page-handler="Reject" class="modal-content">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Reject registration</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p class="small text-muted mb-2">Optional reason (stored for audit).</p>
                                                    <textarea name="reason" class="form-control" rows="3" placeholder="Reason…"></textarea>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">Reject request</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
