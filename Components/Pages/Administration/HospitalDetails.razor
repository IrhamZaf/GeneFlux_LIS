@page "/administration/hospitals/{Id:int}"
@attribute [Authorize(Roles = "SuperAdmin,LabAdmin,Admin")]
@using LIS.Contracts.Administration
@inject AdministrationService AdministrationService

<PageTitle>Hospital Details - Geneflux LIS</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_details == null)
{
    <div class="alert alert-warning mb-0">Hospital not found.</div>
}
else
{
    <div class="lis-hospital-dashboard">
        <div class="card border-0 shadow-sm mb-4 lis-kpi-card">
            <div class="card-body">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
                    <div>
                        <span class='badge @(_details.Hospital.IsActive ? "bg-label-success" : "bg-label-secondary") mb-2'>@(_details.Hospital.IsActive ? "Active" : "Inactive")</span>
                        <h4 class="mb-1">@_details.Hospital.Name</h4>
                        <p class="text-muted mb-1 small">Summary dashboard · Laboratory activity overview</p>
                        <p class="text-muted mb-0">@_details.Hospital.Address</p>
                    </div>
                    <div class="text-muted small text-lg-end">
                        <div><span class="text-body-secondary">Contact</span> · @_details.Hospital.ContactNumber</div>
                        <div><span class="text-body-secondary">Email</span> · @_details.Hospital.ContactEmail</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div class="lis-kpi-icon soft-teal"><i class="icon-base ti tabler-stethoscope"></i></div>
                            <div class="text-end">
                                <span class="text-muted small d-block">Doctors</span>
                                <h3 class="mb-0 mt-1">@_details.TotalDoctors</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div class="lis-kpi-icon soft-slate"><i class="icon-base ti tabler-users"></i></div>
                            <div class="text-end">
                                <span class="text-muted small d-block">Patients</span>
                                <h3 class="mb-0 mt-1">@_details.TotalPatients</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div class="lis-kpi-icon soft-green"><i class="icon-base ti tabler-file-text"></i></div>
                            <div class="text-end">
                                <span class="text-muted small d-block">Reports</span>
                                <h3 class="mb-0 mt-1">@_details.TotalReports</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div class="lis-kpi-icon soft-violet"><i class="icon-base ti tabler-building-community"></i></div>
                            <div class="text-end">
                                <span class="text-muted small d-block">Team</span>
                                <h3 class="mb-0 mt-1">@_details.Users.Count</h3>
                                <span class="text-muted small">assigned users</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-7">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-header border-0 pb-0 d-flex flex-column flex-sm-row justify-content-between align-items-start gap-2">
                        <div>
                            <h5 class="card-title mb-1">Tests most frequently ordered</h5>
                            <p class="text-muted small mb-0">Share of reports at this hospital</p>
                        </div>
                        @if (_details.TotalReports > 0)
                        {
                            <span class="badge bg-label-secondary">@_details.TotalReports total reports</span>
                        }
                    </div>
                    <div class="card-body pt-3">
                        @if (_details.TopTests.Count == 0 || _details.TotalReports == 0)
                        {
                            <p class="text-muted small mb-0">No report history yet — statistics will appear once reports are filed for this hospital.</p>
                        }
                        else
                        {
                            @for (var i = 0; i < _details.TopTests.Count; i++)
                            {
                                var t = _details.TopTests[i];
                                var barIdx = i % 6;
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 mb-1">
                                        <span class="small text-body-secondary text-truncate" title="@t.TestName">@t.TestName</span>
                                        <span class="small text-muted flex-shrink-0">@t.Count <span class="text-body-secondary">(@t.Percent%)</span></span>
                                    </div>
                                    <div class="lis-test-bar-track">
                                        <div class="lis-test-bar-fill lis-bar-@(barIdx)" style="width: @(Math.Min(100, t.Percent))%;"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-5">
                <div class="card border-0 shadow-sm h-100 lis-kpi-card">
                    <div class="card-header border-0 pb-0">
                        <h5 class="card-title mb-1">Assigned users</h5>
                        <p class="text-muted small mb-0">Staff linked to this hospital</p>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead><tr><th>Name</th><th>Role</th><th class="text-end">Reports</th><th class="text-end">Status</th></tr></thead>
                            <tbody>
                                @foreach (var user in PagedUsers)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@user.FullName</div>
                                            <div class="text-muted small">@user.Email</div>
                                        </td>
                                        <td><span class="text-muted small">@user.Role</span></td>
                                        <td class="text-end">@user.TotalReports</td>
                                        <td class="text-end"><span class='badge @(user.IsActive ? "bg-label-success" : "bg-label-secondary")'>@(user.IsActive ? "Active" : "Inactive")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (UserTotalPages > 1)
                    {
                        <div class="card-footer lis-table-pagination bg-transparent border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <span class="text-muted small mb-0 align-self-center">@UserRangeLabel</span>
                            <nav aria-label="Users pagination" class="flex-shrink-0">
                                <ul class="pagination pagination-sm mb-0 align-items-center">
                                    <li class="page-item @(_userPage <= 1 ? "disabled" : "")">
                                        <button type="button" class="page-link" disabled="@(_userPage <= 1)" @onclick="UserPrevPage">Prev</button>
                                    </li>
                                    <li class="page-item disabled"><span class="page-link">@_userPage / @UserTotalPages</span></li>
                                    <li class="page-item @(_userPage >= UserTotalPages ? "disabled" : "")">
                                        <button type="button" class="page-link" disabled="@(_userPage >= UserTotalPages)" @onclick="UserNextPage">Next</button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        </div>

    <!-- Patient List -->
    <div class="card border-0 shadow-sm">
        <div class="card-header border-0 d-flex align-items-center justify-content-between">
            <h5 class="card-title mb-0">Patients</h5>
            <span class="badge bg-label-secondary">@_patients.Count</span>
        </div>
        @if (_patientsLoading)
        {
            <div class="card-body text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            </div>
        }
        else if (_patients.Count == 0)
        {
            <div class="card-body text-muted small">No patients found for this hospital.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Identity</th>
                            <th>MRN</th>
                            <th>Sex</th>
                            <th>Reports</th>
                            <th>Last Report</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in PagedPatients)
                        {
                            <tr>
                                <td class="fw-semibold">@patient.Name</td>
                                <td>
                                    <span class="badge bg-label-@(patient.IdentityType == IdentityType.NRIC ? "primary" : "info") me-1">@patient.IdentityType</span>
                                    <span class="text-muted small">@patient.IdentityNumber</span>
                                </td>
                                <td class="text-muted small">@(patient.MRN ?? "—")</td>
                                <td class="text-muted small">@patient.Sex</td>
                                <td>@patient.TotalReports</td>
                                <td class="text-muted small">@patient.LastReportDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-label-primary" @onclick="() => ViewPatient(patient.Id)">
                                        <i class="icon-base ti tabler-eye me-1"></i>View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (PatientTotalPages > 1)
            {
                <div class="card-footer lis-table-pagination bg-transparent border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="text-muted small mb-0 align-self-center">@PatientRangeLabel</span>
                    <nav aria-label="Patients pagination" class="flex-shrink-0">
                        <ul class="pagination pagination-sm mb-0 align-items-center">
                            <li class="page-item @(_patientPage <= 1 ? "disabled" : "")">
                                <button type="button" class="page-link" disabled="@(_patientPage <= 1)" @onclick="PatientPrevPage">Prev</button>
                            </li>
                            <li class="page-item disabled"><span class="page-link">@_patientPage / @PatientTotalPages</span></li>
                            <li class="page-item @(_patientPage >= PatientTotalPages ? "disabled" : "")">
                                <button type="button" class="page-link" disabled="@(_patientPage >= PatientTotalPages)" @onclick="PatientNextPage">Next</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
    </div>
}

<!-- Patient Detail Panel -->
@if (_showPatientPanel)
{
    <div class="modal fade show lis-modal-shell" tabindex="-1" aria-modal="true" role="dialog" @onclick="ClosePatientPanel">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl lis-modal-dialog">
            <div class="modal-content lis-modal-content lis-patient-detail-modal" @onclick:stopPropagation="true">
                <div class="modal-header align-items-start">
                    <div class="d-flex flex-column flex-grow-1 gap-1 pe-2 min-w-0">
                        @if (_patientDetailLoading)
                        {
                            <h5 class="modal-title mb-0 d-flex align-items-center gap-2">
                                <i class="icon-base ti tabler-user text-primary"></i>Patient details
                            </h5>
                            <span class="text-muted small">Loading profile…</span>
                        }
                        else if (_patientDetail == null)
                        {
                            <h5 class="modal-title mb-0 d-flex align-items-center gap-2">
                                <i class="icon-base ti tabler-user text-primary"></i>Patient details
                            </h5>
                        }
                        else
                        {
                            <span class="patient-detail-kicker">Patient profile</span>
                            <h5 class="patient-detail-hero-name mb-0 text-break">@_patientDetail.Name</h5>
                            <div class="d-flex flex-wrap gap-2 align-items-center mt-1">
                                <span class="badge bg-label-primary text-wrap text-start">@_details?.Hospital.Name</span>
                                @if (_patientDetail.Reports.Count > 0)
                                {
                                    <span class="text-muted small">@_patientDetail.Reports.Count linked report@(_patientDetail.Reports.Count == 1 ? "" : "s")</span>
                                }
                            </div>
                        }
                    </div>
                    <button type="button" class="btn-close lis-modal-close mt-0" @onclick="ClosePatientPanel" aria-label="Close"></button>
                </div>

                <div class="modal-body lis-modal-body pt-3">
                    @if (_patientDetailLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else if (_patientDetail == null)
                    {
                        <div class="alert alert-warning mb-0">Patient not found.</div>
                    }
                    else
                    {
                        <div class="patient-detail-section mb-3">
                            <div class="patient-detail-section-header">
                                <div class="patient-detail-section-title">Demographics</div>
                            </div>
                            <div class="patient-detail-grid row g-3">
                                <div class="col-sm-6 col-lg-4">
                                    <div class="patient-detail-field-label">Sex</div>
                                    <div class="patient-detail-field-value fw-medium">@_patientDetail.Sex</div>
                                </div>
                                <div class="col-sm-6 col-lg-4">
                                    <div class="patient-detail-field-label">
                                        @(_patientDetail.IdentityType == IdentityType.NRIC ? "NRIC" : "Passport")
                                    </div>
                                    <div class="patient-detail-field-value fw-medium font-monospace">
                                        @(_patientDetail.IdentityType == IdentityType.NRIC
                                            ? (_patientDetail.NRIC ?? "—")
                                            : (_patientDetail.PassportNo ?? "—"))
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-4">
                                    <div class="patient-detail-field-label">MRN</div>
                                    <div class="patient-detail-field-value fw-medium font-monospace">@(_patientDetail.MRN ?? "—")</div>
                                </div>
                                @if (_patientDetail.DateOfBirth.HasValue)
                                {
                                    <div class="col-sm-6 col-lg-4">
                                        <div class="patient-detail-field-label">Date of birth</div>
                                        <div class="patient-detail-field-value fw-medium">@_patientDetail.DateOfBirth.Value.ToString("dd/MM/yyyy")</div>
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_patientDetail.DoctorsSummary))
                            {
                                <div class="patient-detail-attending">
                                    <div class="patient-detail-field-label">Attending doctor(s)</div>
                                    <div class="patient-detail-field-value fw-semibold">@_patientDetail.DoctorsSummary</div>
                                </div>
                            }
                        </div>

                        <div class="patient-detail-section">
                            <div class="patient-detail-section-header">
                                <div class="patient-detail-section-title">Report history</div>
                                <span class="text-muted small fw-normal text-uppercase patient-detail-hospital-eyebrow">@_details?.Hospital.Name</span>
                            </div>
                            @if (_patientDetail.Reports.Count == 0)
                            {
                                <div class="p-4 text-center text-muted small">No reports found for this hospital.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table patient-detail-report-table mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Reference</th>
                                                <th>Doctor</th>
                                                <th>Test</th>
                                                <th>Reporting date</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var r in PagedModalReports)
                                            {
                                                <tr>
                                                    <td class="fw-semibold text-nowrap">@r.ReferenceNumber</td>
                                                    <td>@(string.IsNullOrWhiteSpace(r.DoctorName) ? "—" : r.DoctorName)</td>
                                                    <td class="text-break patient-detail-test-cell">@r.TestName</td>
                                                    <td class="text-nowrap text-muted small">
                                                        @(r.ReportingDate.HasValue
                                                            ? r.ReportingDate.Value.ToString("dd/MM/yyyy HH:mm")
                                                            : r.UpdatedAt.ToString("dd/MM/yyyy"))
                                                    </td>
                                                    <td>
                                                        <span class="badge @StatusBadge(r.Status)">@GetPatientModalStatusLabel(r.Status)</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                @if (ModalReportTotalPages > 1)
                                {
                                    <div class="lis-table-pagination border-top px-3 py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                        <span class="text-muted small mb-0 align-self-center">@ModalReportRangeLabel</span>
                                        <nav aria-label="Reports pagination" class="flex-shrink-0">
                                            <ul class="pagination pagination-sm mb-0 align-items-center">
                                                <li class="page-item @(_modalReportPage <= 1 ? "disabled" : "")">
                                                    <button type="button" class="page-link" disabled="@(_modalReportPage <= 1)" @onclick="ModalReportPrevPage">Prev</button>
                                                </li>
                                                <li class="page-item disabled"><span class="page-link">@_modalReportPage / @ModalReportTotalPages</span></li>
                                                <li class="page-item @(_modalReportPage >= ModalReportTotalPages ? "disabled" : "")">
                                                    <button type="button" class="page-link" disabled="@(_modalReportPage >= ModalReportTotalPages)" @onclick="ModalReportNextPage">Next</button>
                                                </li>
                                            </ul>
                                        </nav>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>

                <div class="modal-footer border-top lis-modal-footer">
                    <button type="button" class="btn btn-label-secondary" @onclick="ClosePatientPanel">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private const int UserPageSize = 5;
    private const int PatientPageSize = 10;
    private const int ModalReportPageSize = 10;

    private HospitalDetailsDto? _details;
    private List<HospitalPatientDto> _patients = new();
    private PatientDetailDto? _patientDetail;

    private bool _loading = true;
    private bool _patientsLoading = true;
    private bool _patientDetailLoading;
    private bool _showPatientPanel;

    private int _userPage = 1;
    private int _patientPage = 1;
    private int _modalReportPage = 1;

    private IEnumerable<HospitalUserDto> PagedUsers =>
        _details?.Users.Skip((_userPage - 1) * UserPageSize).Take(UserPageSize) ?? Enumerable.Empty<HospitalUserDto>();

    private int UserTotalPages =>
        _details == null || _details.Users.Count == 0 ? 0 : (int)Math.Ceiling(_details.Users.Count / (double)UserPageSize);

    private string UserRangeLabel =>
        _details == null || _details.Users.Count == 0
            ? "No users"
            : $"Showing {Math.Min((_userPage - 1) * UserPageSize + 1, _details.Users.Count)}–{Math.Min(_userPage * UserPageSize, _details.Users.Count)} of {_details.Users.Count}";

    private IEnumerable<HospitalPatientDto> PagedPatients =>
        _patients.Skip((_patientPage - 1) * PatientPageSize).Take(PatientPageSize);

    private int PatientTotalPages =>
        _patients.Count == 0 ? 0 : (int)Math.Ceiling(_patients.Count / (double)PatientPageSize);

    private string PatientRangeLabel =>
        _patients.Count == 0
            ? "No patients"
            : $"Showing {Math.Min((_patientPage - 1) * PatientPageSize + 1, _patients.Count)}–{Math.Min(_patientPage * PatientPageSize, _patients.Count)} of {_patients.Count}";

    private IEnumerable<PatientReportDto> PagedModalReports =>
        _patientDetail?.Reports.Skip((_modalReportPage - 1) * ModalReportPageSize).Take(ModalReportPageSize)
        ?? Enumerable.Empty<PatientReportDto>();

    private int ModalReportTotalPages =>
        _patientDetail == null || _patientDetail.Reports.Count == 0
            ? 0
            : (int)Math.Ceiling(_patientDetail.Reports.Count / (double)ModalReportPageSize);

    private string ModalReportRangeLabel =>
        _patientDetail == null || _patientDetail.Reports.Count == 0
            ? ""
            : $"Showing {Math.Min((_modalReportPage - 1) * ModalReportPageSize + 1, _patientDetail.Reports.Count)}–{Math.Min(_modalReportPage * ModalReportPageSize, _patientDetail.Reports.Count)} of {_patientDetail.Reports.Count}";

    protected override async Task OnInitializedAsync()
    {
        _details = await AdministrationService.GetHospitalDetailsAsync(Id);
        _loading = false;

        _patients = await AdministrationService.GetHospitalPatientsAsync(Id);
        _patientsLoading = false;
    }

    private void UserPrevPage()
    {
        if (_userPage > 1) _userPage--;
    }

    private void UserNextPage()
    {
        if (_userPage < UserTotalPages) _userPage++;
    }

    private void PatientPrevPage()
    {
        if (_patientPage > 1) _patientPage--;
    }

    private void PatientNextPage()
    {
        if (_patientPage < PatientTotalPages) _patientPage++;
    }

    private void ModalReportPrevPage()
    {
        if (_modalReportPage > 1) _modalReportPage--;
    }

    private void ModalReportNextPage()
    {
        if (_modalReportPage < ModalReportTotalPages) _modalReportPage++;
    }

    private async Task ViewPatient(int patientId)
    {
        _modalReportPage = 1;
        _showPatientPanel = true;
        _patientDetail = null;
        _patientDetailLoading = true;
        StateHasChanged();

        _patientDetail = await AdministrationService.GetPatientDetailAsync(patientId, Id);
        _patientDetailLoading = false;
    }

    private void ClosePatientPanel()
    {
        _showPatientPanel = false;
        _patientDetail = null;
        _modalReportPage = 1;
    }

    private static string StatusBadge(ReportStatus status) => status switch
    {
        ReportStatus.Draft => "bg-label-secondary",
        ReportStatus.PendingReview => "bg-label-warning",
        ReportStatus.Approved => "bg-label-success",
        ReportStatus.Archived => "bg-label-dark",
        _ => "bg-label-secondary"
    };

    private static string GetPatientModalStatusLabel(ReportStatus status) => status switch
    {
        ReportStatus.PendingReview => "Pending review",
        _ => status.ToString()
    };
}
