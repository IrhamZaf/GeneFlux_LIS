@page "/"
@page "/blazor-dashboard"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject CurrentUserService CurrentUserService
@inject DashboardService DashboardService
@inject IJSRuntime JS
@using LIS.Contracts.Dashboard

<PageTitle>Dashboard - Geneflux LIS</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_currentUser == null)
{
    <div class="alert alert-warning mb-0">Unable to load dashboard context.</div>
}
else
{
    <div class="lis-admin-dash">

        <!-- KPI Row -->
        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-dash-kpi">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span class="text-muted small d-block mb-1">Total Reports</span>
                                <h3 class="mb-0">@_dashboard.Stats.TotalReports</h3>
                            </div>
                            <div class="lis-dash-kpi-icon bg-label-primary"><i class="icon-base ti tabler-file-text"></i></div>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <span class="badge bg-label-success small">@_dashboard.Stats.CompletedReports approved</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-dash-kpi">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span class="text-muted small d-block mb-1">Pending</span>
                                <h3 class="mb-0">@_dashboard.Stats.PendingReports</h3>
                            </div>
                            <div class="lis-dash-kpi-icon bg-label-warning"><i class="icon-base ti tabler-clock"></i></div>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Drafts &amp; pending review</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-dash-kpi">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span class="text-muted small d-block mb-1">Patients</span>
                                <h3 class="mb-0">@_dashboard.Stats.TotalPatients</h3>
                            </div>
                            <div class="lis-dash-kpi-icon bg-label-info"><i class="icon-base ti tabler-users"></i></div>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Distinct patient records</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 lis-dash-kpi">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span class="text-muted small d-block mb-1">Hospitals</span>
                                <h3 class="mb-0">@_dashboard.Stats.TotalHospitals</h3>
                            </div>
                            <div class="lis-dash-kpi-icon bg-label-secondary"><i class="icon-base ti tabler-building-hospital"></i></div>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <span class="badge bg-label-secondary small">@_dashboard.Stats.TotalUsers users</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Row 2: Monthly trend + Status donut -->
        <div class="row g-4 mb-4">
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 pb-0">
                        <h5 class="card-title mb-1">Report Trend</h5>
                        <p class="text-muted small mb-0">Reports created over the last 6 months</p>
                    </div>
                    <div class="card-body">
                        <div id="adminTrendChart"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 pb-0">
                        <h5 class="card-title mb-1">Report Status</h5>
                        <p class="text-muted small mb-0">Current distribution</p>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <div id="adminStatusChart" style="width:100%;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Row 3: Top Tests + Hospital Volume -->
        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 pb-0 d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="card-title mb-1">Top 5 Tests</h5>
                            <p class="text-muted small mb-0">Most ordered test types</p>
                        </div>
                        <span class="badge bg-label-secondary">@_dashboard.TopTests.Count types</span>
                    </div>
                    <div class="card-body">
                        @if (_dashboard.TopTests.Count == 0)
                        {
                            <p class="text-muted small py-4 text-center mb-0">No test data yet.</p>
                        }
                        else
                        {
                            <div id="adminTopTestsChart"></div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 pb-0 d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="card-title mb-1">Reports by Hospital</h5>
                            <p class="text-muted small mb-0">Top hospitals by volume</p>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (_dashboard.HospitalVolume.Count == 0)
                        {
                            <p class="text-muted small py-4 text-center mb-0">No report data yet.</p>
                        }
                        else
                        {
                            <div id="adminHospitalChart"></div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row g-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 pb-0 d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title mb-1">Recent Activity</h5>
                            <p class="text-muted small mb-0">Latest report and patient activity</p>
                        </div>
                    </div>
                    <div class="card-body pt-2">
                        @if (_dashboard.RecentActivity.Count == 0)
                        {
                            <div class="py-4 text-center text-muted small">No recent activity available yet.</div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var item in _dashboard.RecentActivity)
                                {
                                    <a href="@item.Href" class="list-group-item list-group-item-action px-0 border-0">
                                        <div class="d-flex justify-content-between align-items-start gap-3">
                                            <div class="d-flex align-items-start gap-3">
                                                <div class="lis-activity-icon @(item.Type == "Report" ? "bg-label-success" : "bg-label-info")">
                                                    <i class="icon-base ti @(item.Type == "Report" ? "tabler-file-text" : "tabler-user")"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold small">@item.Title</div>
                                                    <div class="text-muted small">@item.Detail</div>
                                                </div>
                                            </div>
                                            <small class="text-muted text-nowrap">@item.ActivityAt.ToString("dd/MM HH:mm")</small>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
}

@code {
    private DashboardResponse _dashboard = new();
    private ApplicationUser? _currentUser;
    private bool _loading = true;
    private bool _chartsRendered;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            _loading = false;
            return;
        }

        _currentUser = await CurrentUserService.GetCurrentUserAsync(authState.User);
        if (_currentUser != null)
            await LoadDashboardAsync();

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chartsRendered && _currentUser != null && !_loading)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task LoadDashboardAsync()
    {
        if (_currentUser == null) return;
        _dashboard = await DashboardService.GetDashboardAsync(_currentUser, null);
    }

    private async Task RenderChartsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("initAdminDashboard",
                _dashboard.TopTests,
                _dashboard.StatusBreakdown,
                _dashboard.MonthlyTrend,
                _dashboard.HospitalVolume);
        }
        catch { /* ApexCharts not yet loaded */ }
    }
}
