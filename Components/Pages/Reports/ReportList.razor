@page "/reports"
@attribute [Authorize]
@using LIS.Models
@inject ReportService ReportService
@inject DropdownService DropdownService
@inject ToastService ToastService
@inject PdfExportService PdfService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@using LIS.Data
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject RoleAccessService RoleAccess
@inject CurrentUserService CurrentUserService

<PageTitle>Reports - Geneflux LIS</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_currentUser == null || !RoleAccess.CanAccessReports(_currentUser.Role))
{
    <div class="card workflow-guard-card border-warning">
        <div class="card-body p-4">
            <span class="badge bg-label-warning mb-3">Restricted Workspace</span>
            <h4 class="mb-2">Reports is not available for your role</h4>
            <p class="text-muted mb-3">Only approved roles can access the unified report workspace.</p>
            <a href="/" class="btn btn-primary">
                <i class="icon-base ti tabler-arrow-right me-1"></i>Back to dashboard
            </a>
        </div>
    </div>
}
else
{
    @if (_showFilter)
    {
        <div class="@(_showDialog ? "pe-none user-select-none opacity-50" : null)">
            <FilterPanel Filter="_filter"
                         OnApply="ApplyFilters"
                         OnReset="ResetFilters"
                         ShowHospital="_showHospitalFilter"
                         ShowDoctor="_showDoctorFilter"
                         DoctorCompactLayout="_isDoctor"
                         HospitalStaffCompactLayout="_isHospitalStaffCompactFilter"
                         Tests="_tests"
                         Hospitals="_hospitals"
                         Doctors="_doctors" />
        </div>
    }

    <div class="card">
        <div class="card-header border-0">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h4 class="card-title mb-1">Reports</h4>
                    <p class="text-muted mb-0 small">@GetStatusDescriptionForActiveTab()</p>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    @if (_canCreateReports)
                    {
                        <button type="button" class="btn btn-primary" @onclick="OpenCreateDialog" disabled="@_showDialog">
                            <i class="icon-base ti tabler-upload me-1"></i>Upload Report
                        </button>
                    }
                    @if (_tableLoading)
                    {
                        <span class="badge bg-label-warning">Loading...</span>
                    }
                </div>
            </div>
            @if (_isClinicalWorkspace)
            {
                <div class="mt-3 border-top pt-3">
                    <ul class="nav nav-pills flex-wrap gap-2">
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_doctorWorkspaceTab == "all" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectDoctorAllTab">
                                All
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetDoctorAllTabCount()</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_doctorWorkspaceTab == "completed" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectDoctorCompletedTab">
                                Completed
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetDoctorCompletedTabCount()</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_doctorWorkspaceTab == "pending" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectDoctorPendingTab">
                                Pending Reports
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetDoctorPendingTabCount()</span>
                            </button>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <div class="mt-3 border-top pt-3">
                    <ul class="nav nav-pills flex-wrap gap-2">
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_workspaceTab == "all" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectAllWorkspaceTab">
                                All
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetAllWorkspaceCount()</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_workspaceTab == "draft" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectDraftWorkspaceTab">
                                Draft
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetStatusCount(ReportStatus.Draft)</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button"
                                    class='nav-link @(_workspaceTab == "submitted" ? "active" : "")'
                                    disabled="@_showDialog"
                                    @onclick="SelectSubmittedWorkspaceTab">
                                Submitted
                                <span class="badge rounded-pill bg-white text-dark ms-2">@GetSubmittedPipelineCount()</span>
                            </button>
                        </li>
                    </ul>
                </div>
            }
        </div>
        <div class="card-datatable table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="text-uppercase small fw-bold">Ref No.</th>
                        @if (_isHospitalStaffTable)
                        {
                            <th class="text-uppercase small fw-bold">Doctor Name</th>
                        }
                        else if (!_isDoctor)
                        {
                            <th class="text-uppercase small fw-bold">Hospital Name</th>
                            <th class="text-uppercase small fw-bold">Doctor Name</th>
                            <th class="text-uppercase small fw-bold">Specialization</th>
                        }
                        <th class="text-uppercase small fw-bold">Patient Name</th>
                        <th class="text-uppercase small fw-bold">Patient MRN No.</th>
                        <th class="text-uppercase small fw-bold">Patient NRIC</th>
                        <th class="text-uppercase small fw-bold">Patient Passport No.</th>
                        <th class="text-uppercase small fw-bold">Test Name</th>
                        <th class="text-uppercase small fw-bold">Reporting Date &amp; Time</th>
                        <th class="text-uppercase small fw-bold">Status</th>
                        <th class="text-end text-uppercase small fw-bold">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_reports.Count == 0)
                    {
                        <tr>
                            <td colspan="@TableColSpan" class="text-center py-4 text-muted">
                                No reports found for @GetActiveFilterLabel(). Try adjusting your filters.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var report in _reports)
                        {
                            <tr>
                                <td class="fw-semibold">@report.ReferenceNumber</td>
                                @if (_isHospitalStaffTable)
                                {
                                    <td>@report.Doctor?.Name</td>
                                }
                                else if (!_isDoctor)
                                {
                                    <td>@report.Hospital?.Name</td>
                                    <td>@report.Doctor?.Name</td>
                                    <td>@(report.Doctor?.Specialty ?? "—")</td>
                                }
                                <td>@report.Patient?.Name</td>
                                <td>@report.Patient?.MRN</td>
                                <td>@(_isClinicalWorkspace ? (report.Patient?.NRIC ?? "—") : (report.Patient?.IdentityType == IdentityType.NRIC ? (report.Patient.NRIC ?? "—") : "—"))</td>
                                <td>@(report.Patient?.PassportNo ?? "—")</td>
                                <td>@report.Test?.Name</td>
                                <td>@FormatReportingDateTime(report)</td>
                                <td><span class="badge @GetRowStatusBadge(report.Status)">@GetRowStatusLabel(report.Status)</span></td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 px-2">
                                        @foreach (var action in GetActions(report))
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-icon @action.CssClass"
                                                    title="@action.Title"
                                                    disabled="@_showDialog"
                                                    @onclick="action.Handler">
                                                <i class="@action.Icon"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer border-top d-flex flex-wrap justify-content-between align-items-center py-2 px-4">
            <div class="text-muted small">
                @if (_totalCount == 0)
                {
                    <span>Showing 0 entries</span>
                }
                else
                {
                    <span>Showing @((_filter.Page - 1) * _filter.PageSize + 1) to @Math.Min(_filter.Page * _filter.PageSize, _totalCount) of @_totalCount entries</span>
                }
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class='page-item @(_filter.Page == 1 || _showDialog ? "disabled" : "")'>
                        <button class="page-link" disabled="@_showDialog" @onclick="() => ChangePage(_filter.Page - 1)"><i class="ti tabler-chevron-left"></i></button>
                    </li>
                    @for (var i = 1; i <= TotalPages; i++)
                    {
                        var pageNum = i;
                        <li class='page-item @(_filter.Page == pageNum ? "active" : "")'>
                            <button class="page-link" disabled="@_showDialog" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class='page-item @(_filter.Page == TotalPages || TotalPages == 0 || _showDialog ? "disabled" : "")'>
                        <button class="page-link" disabled="@_showDialog" @onclick="() => ChangePage(_filter.Page + 1)"><i class="ti tabler-chevron-right"></i></button>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    @if (_showDialog)
    {
        <UploadReportDialog @key="_uploadReportDialogKey"
                            ExistingReport="@_selectedReport"
                            CurrentUser="@_currentUser"
                            ReadOnly="@_dialogReadOnly"
                            CanApprove="@(_currentUser != null && RoleAccess.CanApproveReports(_currentUser.Role))"
                            CanReject="@(_currentUser != null && RoleAccess.CanRejectReports(_currentUser.Role))"
                            OnApprove="HandleApproveFromDialog"
                            OnReject="HandleRejectFromDialog"
                            OnClose="HandleDialogClose" />
    }

    @if (_showDeleteDialog && _selectedReport != null)
    {
        <DeleteConfirmDialog Title="Delete Report"
                             Message="This draft report and its associated test results will be permanently removed."
                             ItemLabel="Reference"
                             ReferenceNumber="@_selectedReport.ReferenceNumber"
                             ConfirmText="Delete"
                             OnClose="HandleDeleteConfirm" />
    }
}

@code {
    private List<Report> _reports = new();
    private List<Test> _tests = new();
    private List<Hospital> _hospitals = new();
    private List<Doctor> _doctors = new();
    private Dictionary<ReportStatus, int> _statusCounts = new();
    private ReportFilter _filter = new();
    private int _totalCount;

    private bool _loading = true;
    private bool _tableLoading;
    private bool _showFilter = true;
    private bool _showDialog;
    private bool _dialogReadOnly;
    private bool _showDeleteDialog;
    private CancellationTokenSource? _searchDebounce;

    private Guid _uploadReportDialogKey;
    private Report? _selectedReport;
    private ApplicationUser? _currentUser;
    private bool _isDoctor;
    private bool _isClinicalWorkspace;
    private bool _isHospitalStaffTable;
    /// <summary>For lab workspace tabs: all | draft | submitted.</summary>
    private string _workspaceTab = "all";

    /// <summary>For doctor / head nurse / lab manager tabs: all | completed | pending (maps to <see cref="ReportFilter.DoctorWorkspaceTab"/>).</summary>
    private string _doctorWorkspaceTab = "all";

    private bool _canCreateReports => _currentUser != null && RoleAccess.CanCreateReports(_currentUser.Role);
    private bool _showHospitalFilter => _currentUser?.Role is UserRole.SuperAdmin or UserRole.LabAdmin;
    private bool _showDoctorFilter => _currentUser?.Role is not UserRole.Doctor;
    /// <summary>Head nurse / lab manager filter panel (no hospital row; doctor name as text).</summary>
    private bool _isHospitalStaffCompactFilter =>
        _currentUser?.Role is UserRole.HeadNurse or UserRole.LabManager;

    private int TableColSpan => _isDoctor ? 9 : _isHospitalStaffTable ? 10 : 12;

    private int TotalPages => (int)Math.Ceiling((double)_totalCount / _filter.PageSize);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            _loading = false;
            return;
        }

        _currentUser = await CurrentUserService.GetCurrentUserAsync(authState.User);
        if (_currentUser == null)
        {
            _loading = false;
            return;
        }

        _filter.UserRole = _currentUser.Role;
        _filter.UserId = _currentUser.Id;
        _filter.UserEmail = _currentUser.Email;
        _filter.DoctorId = _currentUser.DoctorId;
        _filter.HospitalId = _currentUser.HospitalId;
        _filter.AccessibleHospitalIds = CurrentUserService.GetAccessibleHospitalIds(_currentUser).ToList();
        _isDoctor = _currentUser.Role == UserRole.Doctor;
        _isHospitalStaffTable = _currentUser.Role is UserRole.HeadNurse or UserRole.LabManager;
        _isClinicalWorkspace = _currentUser.Role is UserRole.Doctor or UserRole.HeadNurse or UserRole.LabManager;
        if (_isClinicalWorkspace)
        {
            _filter.Status = null;
            _filter.SubmittedOnlyTab = false;
            _filter.DoctorWorkspaceTab = "all";
            _doctorWorkspaceTab = "all";
        }
        else
        {
            _workspaceTab = "all";
            _filter.Status = null;
            _filter.SubmittedOnlyTab = false;
        }

        _tests = await DropdownService.GetTestsAsync();
        _hospitals = await DropdownService.GetHospitalsAsync();
        _doctors = await DropdownService.GetDoctorsAsync(_filter.FilterHospitalId);

        await RefreshData();
        _loading = false;
    }

    private async Task RefreshData()
    {
        await LoadReports();
        await LoadStatusCounts();
    }

    private async Task LoadReports()
    {
        _tableLoading = true;
        StateHasChanged();

        var (reports, totalCount) = await ReportService.GetReportsAsync(_filter);
        _reports = reports;
        _totalCount = totalCount;

        _tableLoading = false;
        StateHasChanged();
    }

    private async Task LoadStatusCounts()
    {
        _statusCounts = await ReportService.GetStatusCountsAsync(new ReportFilter
        {
            UserRole = _filter.UserRole,
            UserId = _filter.UserId,
            UserEmail = _filter.UserEmail,
            DoctorId = _filter.DoctorId,
            HospitalId = _filter.HospitalId,
            AccessibleHospitalIds = _filter.AccessibleHospitalIds.ToList(),
            FilterHospitalId = _filter.FilterHospitalId,
            FilterDoctorId = _filter.FilterDoctorId,
            HospitalSearch = _filter.HospitalSearch,
            DoctorSearch = _filter.DoctorSearch,
            PatientName = _filter.PatientName,
            NRIC = _filter.NRIC,
            MRN = _filter.MRN,
            PassportNo = _filter.PassportNo,
            DoctorSpecialty = _filter.DoctorSpecialty,
            FilterTestId = _filter.FilterTestId,
            DateFrom = _filter.DateFrom,
            DateTo = _filter.DateTo,
            SearchTerm = _filter.SearchTerm,
            SubmittedOnlyTab = false,
            DoctorWorkspaceTab = null,
            Status = null
        });
    }

    private async Task ApplyFilters()
    {
        _filter.Page = 1;
        _doctors = await DropdownService.GetDoctorsAsync(_filter.FilterHospitalId);
        await RefreshData();
    }

    private async Task ResetFilters()
    {
        _filter.Page = 1;
        if (_isClinicalWorkspace)
        {
            _doctorWorkspaceTab = "all";
            _filter.DoctorWorkspaceTab = "all";
        }

        _doctors = await DropdownService.GetDoctorsAsync(null);
        await RefreshData();
    }

    private async Task SelectAllWorkspaceTab()
    {
        _workspaceTab = "all";
        _filter.Status = null;
        _filter.SubmittedOnlyTab = false;
        _filter.Page = 1;
        await LoadReports();
    }

    private async Task SelectDraftWorkspaceTab()
    {
        _workspaceTab = "draft";
        _filter.Status = ReportStatus.Draft;
        _filter.SubmittedOnlyTab = false;
        _filter.Page = 1;
        await LoadReports();
    }

    private async Task SelectSubmittedWorkspaceTab()
    {
        _workspaceTab = "submitted";
        _filter.Status = null;
        _filter.SubmittedOnlyTab = true;
        _filter.Page = 1;
        await LoadReports();
    }

    private int GetStatusCount(ReportStatus status) =>
        _statusCounts.TryGetValue(status, out var count) ? count : 0;

    private int GetAllWorkspaceCount() => _statusCounts.Values.Sum();

    private int GetSubmittedPipelineCount() =>
        GetStatusCount(ReportStatus.PendingReview) +
        GetStatusCount(ReportStatus.Approved) +
        GetStatusCount(ReportStatus.Archived);

    private int GetDoctorPendingTabCount() =>
        GetStatusCount(ReportStatus.Draft) + GetStatusCount(ReportStatus.PendingReview);

    private int GetDoctorCompletedTabCount() =>
        GetStatusCount(ReportStatus.Approved) + GetStatusCount(ReportStatus.Archived);

    private int GetDoctorAllTabCount() => _statusCounts.Values.Sum();

    private async Task SelectDoctorAllTab()
    {
        _doctorWorkspaceTab = "all";
        _filter.DoctorWorkspaceTab = "all";
        _filter.Page = 1;
        await LoadReports();
    }

    private async Task SelectDoctorCompletedTab()
    {
        _doctorWorkspaceTab = "completed";
        _filter.DoctorWorkspaceTab = "completed";
        _filter.Page = 1;
        await LoadReports();
    }

    private async Task SelectDoctorPendingTab()
    {
        _doctorWorkspaceTab = "pending";
        _filter.DoctorWorkspaceTab = "pending";
        _filter.Page = 1;
        await LoadReports();
    }

    private string GetActiveFilterLabel() =>
        _isClinicalWorkspace
            ? _doctorWorkspaceTab switch
            {
                "pending" => "pending pipeline reports",
                "completed" => "completed reports",
                _ => _isDoctor ? "reports in your scope" : "reports in your hospitals"
            }
            : _workspaceTab == "all"
                ? "all statuses"
                : _workspaceTab == "draft"
                    ? "draft reports"
                    : "submitted reports";

    private string GetStatusDescriptionForActiveTab() =>
        _isClinicalWorkspace
            ? _doctorWorkspaceTab switch
            {
                "pending" => "Reports not yet completed (draft or pending review).",
                "completed" => "Approved and archived reports you can view or download.",
                _ => _isDoctor ? "All reports attributed to you." : "All reports in your assigned hospitals."
            }
            : _workspaceTab == "all"
                ? "All reports in your scope."
                : _workspaceTab == "draft"
                    ? "Draft reports still being prepared."
                    : "Submitted pipeline (pending review, approved, archived).";

    private static string FormatReportingDateTime(Report report)
    {
        var dt = report.ReportingDate ?? report.UpdatedAt;
        return dt.ToString("dd/MM/yyyy HH:mm");
    }

    private static string GetDisplayStatusLabel(ReportStatus status) =>
        status == ReportStatus.Draft ? "Draft" : "Submitted";

    private static string GetDisplayStatusBadge(ReportStatus status) =>
        status == ReportStatus.Draft ? "bg-label-warning" : "bg-label-success";

    private static bool IsDoctorPendingBucket(ReportStatus status) =>
        status is ReportStatus.Draft or ReportStatus.PendingReview;

    private string GetRowStatusLabel(ReportStatus status) =>
        _isClinicalWorkspace
            ? (IsDoctorPendingBucket(status) ? "Pending" : "Completed")
            : GetDisplayStatusLabel(status);

    private string GetRowStatusBadge(ReportStatus status) =>
        _isClinicalWorkspace
            ? (IsDoctorPendingBucket(status) ? "bg-label-warning" : "bg-label-success")
            : GetDisplayStatusBadge(status);

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        _filter.Page = page;
        await LoadReports();
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        _filter.SearchTerm = e.Value?.ToString();
        _filter.Page = 1;

        _searchDebounce?.Cancel();
        _searchDebounce = new CancellationTokenSource();
        var token = _searchDebounce.Token;

        try
        {
            await Task.Delay(350, token);
            if (!token.IsCancellationRequested)
                await RefreshData();
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task ClearSearch()
    {
        _searchDebounce?.Cancel();
        _filter.SearchTerm = null;
        _filter.Page = 1;
        await RefreshData();
    }

    private void OpenCreateDialog()
    {
        _uploadReportDialogKey = Guid.NewGuid();
        _selectedReport = null;
        _dialogReadOnly = false;
        _showDialog = true;
    }

    private async Task OpenDialog(Report report, bool readOnly)
    {
        if (_currentUser == null)
            return;

        _uploadReportDialogKey = Guid.NewGuid();
        _selectedReport = await ReportService.GetByIdAsync(report.Id, _currentUser);
        var forceClinicalReadOnly = _selectedReport != null &&
                                    _currentUser.Role is (UserRole.Doctor or UserRole.HeadNurse or UserRole.LabManager) &&
                                    IsDoctorPendingBucket(_selectedReport.Status);
        _dialogReadOnly = readOnly || forceClinicalReadOnly;
        _showDialog = _selectedReport != null;
    }

    private IReadOnlyList<ReportActionButton> GetActions(Report report)
    {
        var actions = new List<ReportActionButton>();
        if (_currentUser == null)
            return actions;

        if (_currentUser.Role is UserRole.Doctor or UserRole.HeadNurse or UserRole.LabManager)
        {
            if (IsDoctorPendingBucket(report.Status))
                return actions;

            actions.Add(new("View report", "btn-label-secondary", "icon-base ti tabler-eye", () => OpenDialog(report, true)));
            if ((report.Status == ReportStatus.Approved || report.Status == ReportStatus.Archived) &&
                RoleAccess.CanDownloadReports(_currentUser.Role))
            {
                actions.Add(new("Download PDF", "btn-label-success", "icon-base ti tabler-file-type-pdf", () => DownloadPdf(report)));
            }

            return actions;
        }

        if (report.Status == ReportStatus.Draft)
        {
            if (RoleAccess.CanEditDraftReports(_currentUser.Role))
            {
                actions.Add(new("Edit report", "btn-label-primary", "icon-base ti tabler-edit", () => OpenDialog(report, false)));
                if (RoleAccess.CanDeleteDraftReports(_currentUser.Role))
                {
                    actions.Add(new("Delete report", "btn-label-danger", "icon-base ti tabler-trash", () =>
                    {
                        _selectedReport = report;
                        _showDeleteDialog = true;
                        return Task.CompletedTask;
                    }));
                }
            }
            else
            {
                actions.Add(new("View report", "btn-label-secondary", "icon-base ti tabler-eye", () => OpenDialog(report, true)));
            }

            return actions;
        }

        actions.Add(new("View report", "btn-label-secondary", "icon-base ti tabler-eye", () => OpenDialog(report, true)));

        if (report.Status == ReportStatus.PendingReview && RoleAccess.CanEditDraftReports(_currentUser.Role))
            actions.Add(new("Edit report", "btn-label-primary", "icon-base ti tabler-edit", () => OpenDialog(report, false)));

        if (report.Status == ReportStatus.PendingReview && _currentUser.Role is UserRole.SuperAdmin or UserRole.LabAdmin)
        {
            actions.Add(new("Delete report", "btn-label-danger", "icon-base ti tabler-trash", () =>
            {
                _selectedReport = report;
                _showDeleteDialog = true;
                return Task.CompletedTask;
            }));
        }

        if ((report.Status == ReportStatus.Approved || report.Status == ReportStatus.Archived) &&
            RoleAccess.CanDownloadReports(_currentUser.Role))
        {
            actions.Add(new("Download PDF", "btn-label-success", "icon-base ti tabler-file-type-pdf", () => DownloadPdf(report)));
        }

        if (_currentUser.Role is UserRole.SuperAdmin or UserRole.LabAdmin &&
            report.Status is ReportStatus.Approved or ReportStatus.Archived)
        {
            actions.Add(new("Delete report", "btn-label-danger", "icon-base ti tabler-trash", () =>
            {
                _selectedReport = report;
                _showDeleteDialog = true;
                return Task.CompletedTask;
            }));
        }

        return actions;
    }

    private async Task HandleDialogClose(bool _)
    {
        _showDialog = false;
        _dialogReadOnly = false;
        _selectedReport = null;
        await RefreshData();
    }

    private async Task HandleApproveFromDialog(int reportId)
    {
        if (_currentUser == null) return;
        try
        {
            var approved = await ReportService.ApproveAsync(reportId, _currentUser);
            if (approved == null)
                ToastService.ShowToast("Unable to approve this report.", ToastLevel.Warning);
            else
                ToastService.ShowToast("Report approved.", ToastLevel.Success);
        }
        catch (Exception ex) { ToastService.ShowToast(ex.Message, ToastLevel.Error); }
        _showDialog = false;
        _selectedReport = null;
        await RefreshData();
    }

    private async Task HandleRejectFromDialog(int reportId)
    {
        if (_currentUser == null) return;
        try
        {
            var rejected = await ReportService.RejectAsync(reportId, _currentUser);
            if (rejected == null)
                ToastService.ShowToast("Unable to reject this report.", ToastLevel.Warning);
            else
                ToastService.ShowToast("Report returned to draft.", ToastLevel.Success);
        }
        catch (Exception ex) { ToastService.ShowToast(ex.Message, ToastLevel.Error); }
        _showDialog = false;
        _selectedReport = null;
        await RefreshData();
    }

    private async Task HandleDeleteConfirm(bool confirmed)
    {
        _showDeleteDialog = false;
        if (confirmed && _selectedReport != null && _currentUser != null)
        {
            if (await ReportService.DeleteAsync(_selectedReport.Id, _currentUser))
            {
                ToastService.ShowToast("Report deleted.", ToastLevel.Success);
                await RefreshData();
            }
            else
            {
                ToastService.ShowToast("Unable to delete report.", ToastLevel.Warning);
            }
        }

        _selectedReport = null;
    }

    private async Task SubmitReport(Report report)
    {
        if (_currentUser == null)
            return;

        try
        {
            var submitted = await ReportService.SubmitForReviewAsync(report.Id, _currentUser);
            if (submitted == null)
            {
                ToastService.ShowToast("Unable to submit this report.", ToastLevel.Warning);
                return;
            }

            ToastService.ShowToast("Report moved to Pending Review.", ToastLevel.Success);
            await RefreshData();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(ex.Message, ToastLevel.Error);
        }
    }

    private async Task ApproveReport(Report report)
