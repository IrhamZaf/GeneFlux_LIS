@inject UserService UserService
@inject ToastService ToastService

<div class="card">
    <div class="card-header border-0">
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <div>
                    <h4 class="card-title mb-1">@GetRoleLabel() Accounts</h4>
                    <p class="text-muted mb-0">Manage account access, assignments, and activation status.</p>
                </div>
            </div>
            <div class="col-md-7">
                <div class="d-flex flex-wrap justify-content-md-end gap-2">
                    <div class="input-group input-group-merge app-search-input">
                        <span class="input-group-text"><i class="icon-base ti tabler-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search account..." @bind="SearchTerm" @bind:event="oninput" />
                    </div>
                    <button type="button" class="btn btn-primary" @onclick="AddUser">
                        <i class="icon-base ti tabler-user-plus me-1"></i>Create Account
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-datatable table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th class="text-uppercase small fw-bold">Full Name</th>
                    <th class="text-uppercase small fw-bold">Email</th>
                    <th class="text-uppercase small fw-bold">Hospital</th>
                    <th class="text-uppercase small fw-bold">Status</th>
                    <th class="text-end text-uppercase small fw-bold">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (PagedUsers.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">
                            <div class="empty-state-panel py-4">
                                <lord-icon src="https://cdn.lordicon.com/msoeawqm.json"
                                           trigger="loop"
                                           colors="primary:#121331,secondary:#08a88a"
                                           style="width:72px;height:72px">
                                </lord-icon>
                                <h5 class="mt-3 mb-1">No accounts found</h5>
                                <p class="text-muted mb-0">Try another search term or create a new account for this role.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var user in PagedUsers)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-3">
                                        <span class="avatar-initial rounded-circle bg-label-primary">
                                            @GetInitials(user.FullName)
                                        </span>
                                    </div>
                                    <div class="fw-semibold">@user.FullName</div>
                                </div>
                            </td>
                            <td>
                                <span class="text-body">@user.Email</span>
                            </td>
                            <td>
                                <span class="badge bg-label-info">@(user.Hospital?.Name ?? "Unassigned")</span>
                            </td>
                            <td>
                                <span class='badge @(user.IsActive ? "bg-label-success" : "bg-label-secondary") text-uppercase'>
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-icon btn-text-secondary rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="icon-base ti tabler-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <button type="button" class="dropdown-item" @onclick="() => EditUser(user)">
                                                <i class="icon-base ti tabler-edit me-2"></i>Edit
                                            </button>
                                        </li>
                                        <li>
                                            <button type="button" class="dropdown-item" @onclick="() => DeleteUser(user)">
                                                <i class="icon-base ti tabler-user-off me-2"></i>Deactivate
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer border-top d-flex flex-wrap justify-content-between align-items-center py-2 px-4">
        <div class="text-muted small">
            Showing @((_currentPage - 1) * _pageSize + 1) to @Math.Min(_currentPage * _pageSize, FilteredUsers.Count) of @FilteredUsers.Count entries
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class='page-item @(_currentPage == 1 ? "disabled" : "")'>
                    <button class="page-link" @onclick="() => ChangePage(_currentPage - 1)"><i class="ti tabler-chevron-left"></i></button>
                </li>
                @for (int i = 1; i <= TotalPages; i++)
                {
                    var pageNum = i;
                    <li class='page-item @(_currentPage == pageNum ? "active" : "")'>
                        <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class='page-item @(_currentPage == TotalPages || TotalPages == 0 ? "disabled" : "")'>
                    <button class="page-link" @onclick="() => ChangePage(_currentPage + 1)"><i class="ti tabler-chevron-right"></i></button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@if (_showUserModal)
{
    <UserFormDialog Role="@Role" ExistingUser="@_userToEdit" Hospitals="@Hospitals" OnClose="HandleUserModalClose" />
}

@if (_showDeleteModal && _userToDelete != null)
{
    <DeleteConfirmDialog Title="Deactivate Account"
                         Message="This account will lose access to the LIS until it is reactivated."
                         ItemLabel="User"
                         ReferenceNumber="@_userToDelete.FullName"
                         ConfirmText="Deactivate"
                         OnClose="HandleDeleteModalClose" />
}

@code {
    [Parameter] public UserRole Role { get; set; }
    [Parameter] public List<ApplicationUser> Users { get; set; } = new();
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public List<Hospital> Hospitals { get; set; } = new();

    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                _currentPage = 1;
            }
        }
    }

    private string _searchTerm = string.Empty;
    private bool _showUserModal;
    private ApplicationUser? _userToEdit;
    private bool _showDeleteModal;
    private ApplicationUser? _userToDelete;

    private int _currentPage = 1;
    private int _pageSize = 10;

    private List<ApplicationUser> FilteredUsers =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? Users
            : Users.Where(user =>
                user.FullName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (user.Email?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (user.Hospital?.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();

    private List<ApplicationUser> PagedUsers => FilteredUsers
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling((double)FilteredUsers.Count / _pageSize);

    private void ChangePage(int page)
    {
        _currentPage = page;
    }

    private string GetRoleLabel() => Role switch
    {
        UserRole.Doctor => "Doctor",
        UserRole.LabManager => "Lab Manager",
        UserRole.HeadNurse => "Head Nurse",
        UserRole.LabAdmin => "Lab Admin",
        UserRole.SuperAdmin => "Super Admin",
        _ => Role.ToString()
    };

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        return string.IsNullOrWhiteSpace(fullName) ? "U" : fullName[..1].ToUpperInvariant();
    }

    private void AddUser()
    {
        _userToEdit = null;
        _showUserModal = true;
    }

    private void EditUser(ApplicationUser user)
    {
        _userToEdit = user;
        _showUserModal = true;
    }

    private async Task HandleUserModalClose(bool success)
    {
        _showUserModal = false;
        _userToEdit = null;
        if (success) 
        { 
            ToastService.ShowToast("Account updated successfully.", ToastLevel.Success);
            await OnRefresh.InvokeAsync(); 
        }
    }

    private void DeleteUser(ApplicationUser user)
    {
        _userToDelete = user;
        _showDeleteModal = true;
    }

    private async Task HandleDeleteModalClose(bool confirmed)
    {
        _showDeleteModal = false;
        if (confirmed && _userToDelete != null)
        {
            await UserService.DeactivateUserAsync(_userToDelete.Id);
            ToastService.ShowToast("User deactivated.", ToastLevel.Success);
            await OnRefresh.InvokeAsync();
        }
        _userToDelete = null;
    }
}
