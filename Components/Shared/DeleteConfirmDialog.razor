<div class="modal fade show lis-modal-shell" tabindex="-1" aria-modal="true" role="dialog" @onclick="Cancel">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable lis-modal-dialog">
        <div class="modal-content lis-modal-content app-dialog" @onclick:stopPropagation="true">
            <div class="modal-header border-bottom-0 pb-0">
                <div>
                    <h5 class="modal-title text-danger mb-1">
                        <i class="icon-base ti tabler-alert-triangle me-2"></i>@Title
                    </h5>
                    <p class="text-muted mb-0">@Message</p>
                </div>
                <button type="button" class="btn-close lis-modal-close" @onclick="Cancel" aria-label="Close"></button>
            </div>
            <div class="modal-body lis-modal-body pt-3">
                @if (!string.IsNullOrWhiteSpace(ReferenceNumber))
                {
                    <div class="alert alert-warning mb-0">
                        <div class="fw-semibold mb-1">@ItemLabel</div>
                        <div>@ReferenceNumber</div>
                    </div>
                }
            </div>
            <div class="modal-footer border-top lis-modal-footer">
                <button type="button" class="btn btn-label-secondary" @onclick="Cancel">Cancel</button>
                <button type="button" class="btn btn-danger" @onclick="Delete">@ConfirmText</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public string Title { get; set; } = "Delete Item";
    [Parameter] public string Message { get; set; } = "Are you sure you want to continue?";
    [Parameter] public string ItemLabel { get; set; } = "Reference";
    [Parameter] public string ReferenceNumber { get; set; } = "";
    [Parameter] public string ConfirmText { get; set; } = "Delete";

    private async Task Cancel() => await OnClose.InvokeAsync(false);
    private async Task Delete() => await OnClose.InvokeAsync(true);
}
